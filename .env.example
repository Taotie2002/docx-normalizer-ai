# DFGP 知识库配置文件

# LLM API Keys (至少配置一个)
# MINIMAX_API_KEY=your_minimax_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# 模型配置
# DEFAULT_MODEL=minimax-portal/MiniMax-M2.7
# CODER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# AUDITOR_MODEL=nvidia/nemotron-3-super-120b-a12b

# 审计阈值
# AUDIT_PASS_THRESHOLD=90
# AUDIT_WARN_THRESHOLD=80

# 路径配置
# TEMPLATES_DIR=templates
# OUTPUT_DIR=output
